# pg.env — bootstrap-настройки подключения к PostgreSQL
# Этот файл хранится в git как шаблон для первого запуска.
# Если значения пустые, приложение НЕ будет пытаться подключаться к PostgreSQL
# до тех пор, пока вы не сохраните реальные параметры в админке.
#
# После сохранения через UI актуальная конфигурация записывается сервером
# и используется при последующих запусках.

PG_HOST=
PG_PORT=5432
PG_DATABASE=
PG_USER=
PG_PASSWORD=
PG_SSL=false
